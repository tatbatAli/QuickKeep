{
  "manifest_version": 3,
  "name": "QuickKeep",
  "version": "1.1.0",
  "description": "Save any webpage instantly with a note. Sync across devices with Pro. Share pages with your team. Free to start.",

  "permissions": ["storage", "activeTab", "tabs"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "QuickKeep — Save this page",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://us-central1-quickkeep-57a5e.cloudfunctions.net;"
  },

  "host_permissions": [
    "https://*.googleapis.com/*",
    "https://*.firebaseio.com/*",
    "https://us-central1-quickkeep-57a5e.cloudfunctions.net/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "styles.css",
        "firebase-app-compat.js",
        "firebase-auth-compat.js",
        "firebase-firestore-compat.js",
        "firebase-functions-compat.js"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
