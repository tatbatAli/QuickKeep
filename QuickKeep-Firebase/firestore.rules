// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
//
// These rules ensure users can ONLY access their own data.
// No user can read or write another user's entries, folders, or profile.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────

    // Is the request coming from a logged-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Is the logged-in user the owner of this document?
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Is the logged-in user a member of a team?
    function isTeamMember(teamId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
    }

    // Is the logged-in user on a paid plan?
    function isPro() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan in ['pro', 'team'];
    }

    // ── Users collection ──────────────────────────────────────
    // Each user document stores plan, email, paddleSubId.
    // Users can read their own profile.
    // Only Cloud Functions (admin SDK) can write plan upgrades.
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId);
      // Prevent client from self-upgrading plan — only backend webhook can do this
      // But allow updating teamId, role, and other profile fields
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'paddleSubId']);
    }

    // ── Entries collection ────────────────────────────────────
    match /entries/{entryId} {

      // Reading personal entries or team entries
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.teamId != null &&
         resource.data.teamId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId)
      );

      // Creating an entry
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      // Updating — original saver or team owner can update anything
      // Any team member can update reactions only
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.teamId != null &&
         resource.data.teamId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner') ||
        (resource.data.teamId != null &&
         resource.data.teamId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
      );

      // Deleting — original saver or team owner only
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.teamId != null &&
         resource.data.teamId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner')
      );
    }

    // ── Folders collection (Pro feature) ──────────────────────
    match /folders/{folderId} {
      allow read, write: if isOwner(resource.data.userId);
      allow create:      if isOwner(request.resource.data.userId) && isPro();
    }

    // ── Teams collection ──────────────────────────────────────
    match /teams/{teamId} {
      // Members can read their own team (checked via user profile)
      allow read: if isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId == teamId;
      // Team plan users can create a team
      allow create: if isAuth()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds.hasAll([request.auth.uid]);
      // Only the owner can update team settings
      allow update: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // ── Invites collection ────────────────────────────────────
    match /invites/{inviteId} {
      // Anyone with the invite token can read it (to accept it)
      allow read: if isAuth();
      // Only team owners can create invites
      allow create: if isAuth()
        && get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.ownerId
           == request.auth.uid;
      // Mark as accepted — invite recipient only
      allow update: if isAuth()
        && resource.data.email == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['accepted']);
    }

    // ── Comments collection (Team feature) ───────────────────
    match /comments/{commentId} {
      allow read: if isAuth() &&
        isTeamMember(
          get(/databases/$(database)/documents/entries/$(resource.data.entryId)).data.teamId
        );
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      // Authors can delete their own comments
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Activity Feed (Team feature) ─────────────────────────
    match /activity/{activityId} {
      // Team members can read activity for their team
      allow read: if isAuth() &&
        resource.data.teamId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId;
      // Team members can create activity events
      allow create: if isAuth()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.teamId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId;
    }

    // ── Pending upgrades (paid before account creation) ──────────
    match /pending_upgrades/{email} {
      allow read, delete: if isAuth() && request.auth.token.email == email;
      allow write: if false; // only Cloud Functions can write
    }

    // ── Deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
